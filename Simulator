
class Asset:

    def __init__(
        self,
        name,
        asset_type,
        status="operational",
        resilience=100,
        recovery_days=1
    ):

        self.name = name
        self.asset_type = asset_type
        self.status = status
        self.resilience = resilience
        self.recovery_days = recovery_days

        self.dependencies = []
